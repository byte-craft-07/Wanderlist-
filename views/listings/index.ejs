  
<% layout("/layouts/boilerplate") %>


<div class="row justify-content-center">
  <div class="col-12 col-md-10 col-lg-8">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3 class="mb-0">Create New Listing</h3>
      <a href="/listings" class="btn btn-outline-dark">Back to listings</a>
    </div>

    <div class="card shadow-sm border-0">
      <div class="card-body p-4 p-md-5">
        <form method="POST" action="/listings" novalidate class="needs-validation">
          <div class="mb-3">
            <label for="title" class="form-label fw-semibold">Title</label>
            <input
              id="title"
              name="listing[title]"
              type="text"
              class="form-control"
              placeholder="Enter your title"
              required
            >
            <div class="invalid-feedback">This field is required.</div>
          </div>

          <div class="mb-3">
            <label for="description" class="form-label fw-semibold">Description</label>
            <textarea
              id="description"
              name="listing[description]"
              class="form-control"
              rows="4"
              placeholder="Enter your description"
              required
            ></textarea>
            <div class="invalid-feedback">This field is required.</div>
          </div>

          <div class="row g-3">
            <div class="col-12 col-md-6">
              <label for="price" class="form-label fw-semibold">Price (INR)</label>
              <input
                id="price"
                name="listing[price]"
                type="number"
                min="0"
                class="form-control"
                placeholder="Enter your price"
                required
              >
              <div class="invalid-feedback">This field is required.</div>
            </div>
            <div class="col-12 col-md-6">
              <label for="country" class="form-label fw-semibold">Country</label>
              <input
                id="country"
                name="listing[country]"
                type="text"
                class="form-control"
                placeholder="Enter your country"
                required
              >
              <div class="invalid-feedback">This field is required.</div>
            </div>
          </div>

          <div class="mt-3 mb-3">
            <label for="location" class="form-label fw-semibold">Location</label>
            <input
              id="location"
              name="listing[location]"
              type="text"
              class="form-control"
              placeholder="Enter your location"
              required
            >
            <div class="invalid-feedback">This field is required.</div>
          </div>

          <div class="mb-4">
            <label for="imageUrl" class="form-label fw-semibold">Image URL</label>
            <input
              id="imageUrl"
              name="listing[image][url]"
              type="url"
              class="form-control"
              placeholder="Enter url of your image"
            >
          </div>

          <button type="submit" class="btn btn-dark px-4">Create Listing</button>
        </form>
      </div>
    </div>
  </div>
</div>



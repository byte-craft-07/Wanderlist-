<% layout("/layouts/boilerplate") %>


<div class="d-flex justify-content-between align-items-center mb-4">
  <h2 class="mb-0">All listings</h2>
  <a href="/listings/create" class="btn btn-dark">Create new listing</a>
</div>

<div class="row g-4">
  <% for (let listing of alllistings) { %>
    <div class="col-12 col-md-6 col-lg-4">
      <a href="/listings/<%= listing._id %>" class="text-decoration-none text-dark">
        <div class="card h-100 shadow-sm">
          <img
            src="<%= (listing.image && listing.image.url) ? listing.image.url : `https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR9FjQAmUwLA0YQcOi2bR2ksjq8oKvH9uHu9g&s` %>"
            class="card-img-top"
            alt="<%= listing.title %>"
            style="height: 220px; object-fit: cover;"
          >
          <div class="card-body">
            <h5 class="card-title mb-1"><%= listing.title %></h5>
            <p class="card-text text-muted mb-0">
              <%= listing.location %>, <%= listing.country %><hr>
              ₹<%= Number(listing.price).toLocaleString("en-IN") %> / night
            </p>
          </div>
        </div>
      </a>
    </div>
  <% } %>
</div>
